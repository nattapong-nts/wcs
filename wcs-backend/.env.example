# Application Configuration
PORT=3003

# RCS Configuration
RCS_BASE_URL=http://173.249.57.224:8182
RCS_API_KEY=
RCS_TIMEOUT=10000
RCS_RETRY_ATTEMPTS=3
RCS_RETRY_DELAY=1000
RCS_GEN_AGV_SCHEDULING_TASK_API_PATH=/rcms/services/rest/hikRpcService/genAgvSchedulingTask
RCS_CONTINUE_AGV_TASK_API_PATH=/rcms/services/rest/hikRpcService/continueTask

# AGV Configuration
AGV_STANDBY_POSITION=012000BB012000
AGV_DOCK_POSITION=012000BB011000
AGV_NOTIFICATION_POSITION=012000BB013000
AGV_DESTINATION_POSITION=012000BB014000
AGV_CHECK_AGV_STATUS_INTERVAL_MS=5000
AGV_POSITION_TOLERANCE=100

# Modbus Configuration
MODBUS_HOST=localhost
MODBUS_PORT=5020
MODBUS_UNIT_ID=1
MODBUS_TIMEOUT=10000
MODBUS_RECONNECT_DELAY=3000
MODBUS_POLL_INTERVAL_MS=500

# Modbus Digital Input addresses (PLC → WCS)
MODBUS_DI_PICKUP=0
MODBUS_DI_GOODS_LOADED=1
MODBUS_DI_ITEMS_UNLOADED=2

# Modbus Digital Output addresses (WCS → PLC)
MODBUS_DO_AGV_READY=0
MODBUS_DO_REQUEST_ENTER=1
MODBUS_DO_AT_DOCK=2
MODBUS_DO_REQUEST_EXIT=3
MODBUS_DO_TASK_COMPLETE=4